<Window x:Class="NotepadLite.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="NotepadLite"
        Height="760"
        Width="1180"
        MinHeight="520"
        MinWidth="760"
        Background="#F4F6F8"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FBFBFC" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F7F8FA" />
        <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#F1F4F8" />
        <SolidColorBrush x:Key="SurfacePressedBrush" Color="#E8ECF3" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7DCE4" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#C5CCD8" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C6470" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#115EA3" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,8,8,4" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="2"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter Margin="0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E5F1FB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Margin="12,0,12,8"
                                       FontWeight="SemiBold"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Header}" />
                            <Border Grid.Row="1"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E5F1FB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="StatusBarItem">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
    </Window.Resources>
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OpenDocumentClick" InputGestureText="Ctrl+O" />
                <MenuItem Header="_Save" Click="SaveDocumentClick" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Click="SaveDocumentAsClick" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="E_xit" Click="ExitClick" />
            </MenuItem>
            <MenuItem Header="_Language">
                <MenuItem Header="Reload Definitions" Click="ReloadDefinitionsClick" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="LanguageStatusTextBlock" Text="Language: Plain Text" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="DocumentPathTextBlock" Text="Unsaved document" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="176" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               FontWeight="SemiBold"
                               Text="Language" />
                    <ComboBox x:Name="LanguageComboBox"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              DisplayMemberPath="Name"
                              SelectionChanged="LanguageSelectionChanged" />

                    <TextBlock Grid.Column="3"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Built-in language definitions are available automatically." />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#D7D9DE"
                    BorderThickness="1"
                    CornerRadius="8">
                <avalonedit:TextEditor x:Name="Editor"
                                       Background="{StaticResource SurfaceBrush}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       ShowLineNumbers="True"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
