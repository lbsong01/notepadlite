<NotepadPlus>
  <UserLang name="PowerShell" ext="ps1 psm1 psd1">
    <Keywords>
      <Keywords name="Keywords1">function param begin process end if elseif else foreach for while switch return try catch finally throw class enum</Keywords>
      <Keywords name="Keywords2">Get-Item Set-Item Get-ChildItem Select-Object Where-Object ForEach-Object Write-Host Write-Output Test-Path</Keywords>
      <Keywords name="Operators">-eq -ne -gt -lt -ge -le -and -or -not = + - * /</Keywords>
    </Keywords>
    <Delimiters>
      <Delimiter name="string-double" open='&quot;' close='&quot;' />
      <Delimiter name="string-single" open="'" close="'" />
    </Delimiters>
    <Comments>
      <LineComment value="#" />
      <BlockCommentStart value="&lt;#" />
      <BlockCommentEnd value="#&gt;" />
    </Comments>
  </UserLang>
</NotepadPlus>